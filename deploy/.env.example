# ─────────────────────────────────────────────────────────────────────────────
# TidyDAV configuration
#
# Copy this file to `.env` next to compose.example.yaml and adjust the values.
# Only TIDYDAV_SECRET_KEY and TIDYDAV_BASE_URL are required; everything else has
# sensible defaults.
# ─────────────────────────────────────────────────────────────────────────────

# ── Instance (required) ──────────────────────────────────────────────────────

# Key used to sign session cookies. Keep it secret and stable across restarts
# (changing it logs everyone out). Generate one with:  openssl rand -hex 32
TIDYDAV_SECRET_KEY=

# Public base URL under which TidyDAV is reachable. Used to build OIDC redirect
# URLs, ICS subscription links and password-reset links. No trailing slash.
TIDYDAV_BASE_URL=https://dav.example.com

# ── Instance (optional) ──────────────────────────────────────────────────────

# Path to the SQLite database file (inside the container).
#TIDYDAV_DB_PATH=/data/tidydav.db

# Address the HTTP server listens on.
#TIDYDAV_LISTEN_ADDR=:8080

# Log verbosity: debug | info | warn | error
#TIDYDAV_LOG_LEVEL=info

# ── Access mode (optional) ───────────────────────────────────────────────────

# public = every visitor gets an anonymous secret-id, no login required
# auth   = only OIDC or email+password, no anonymous access (default)
# both   = anonymous secret-id AND login are available
#TIDYDAV_ACCESS_MODE=auth

# Allow email+password self-registration (only relevant when auth is enabled).
#TIDYDAV_ALLOW_REGISTRATION=true

# ── OIDC (optional) ──────────────────────────────────────────────────────────
# Works with any OIDC provider (PocketID, Authentik, Keycloak, Google, GitHub…).
# OIDC is enabled automatically once issuer URL and client id are set.

#TIDYDAV_OIDC_ISSUER_URL=https://id.example.com
#TIDYDAV_OIDC_CLIENT_ID=
#TIDYDAV_OIDC_CLIENT_SECRET=
#TIDYDAV_OIDC_SCOPES=openid profile email

# ── SMTP (optional) ──────────────────────────────────────────────────────────
# Required only for password-reset / email-verification mails.

#TIDYDAV_SMTP_HOST=smtp.example.com
#TIDYDAV_SMTP_PORT=587
#TIDYDAV_SMTP_USERNAME=
#TIDYDAV_SMTP_PASSWORD=
#TIDYDAV_SMTP_FROM=tidydav@example.com
# Encryption: starttls | tls | none
#TIDYDAV_SMTP_ENCRYPTION=starttls

# ── Container user / timezone (optional) ─────────────────────────────────────
# Match these to the owner of your data volume so files are not created as root.
# Find your ids on the host with:  id -u  /  id -g

#PUID=1000
#PGID=1000
#TZ=UTC
